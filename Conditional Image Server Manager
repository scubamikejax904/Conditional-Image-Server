definition(
    name: "Conditional Image Server Manager",
    namespace: "scubamikejax904",
    author: "Michael Gartner",
    description: "Manages multiple instances of the Conditional Image Server",
    category: "Convenience",
    iconUrl: "",
    iconX2Url: "",
    oauth: true, // Enable OAuth here so we only have to do it once!
    singleInstance: true, // Only one Manager app is needed
    childApps: [
        [name: "imageServerChild", appName: "Conditional Image Server", namespace: "scubamikejax904"]
    ]
)

preferences {
    page(name: "mainPage")
}

def mainPage() {
    // Ensure the Parent app has an OAuth token
    if (!state.accessToken) {
        try { createAccessToken() } 
        catch (e) { log.warn "Could not create access token. Please enable OAuth in this Manager app's settings." }
    }

    dynamicPage(name: "mainPage", title: "Conditional Image Server Manager", install: true, uninstall: true) {
        
        section("Instructions") {
            paragraph "Use this page to add, remove, and configure your Conditional Image Server instances. Because OAuth is enabled on this Manager app, your child instances will automatically share this token."
        }

        section("Image Server Instances") {
            // Added the 'title' parameter to display custom text for the child app input
            app(name: "imageServerChild", 
                appName: "Conditional Image Server", 
                namespace: "scubamikejax904", 
                multiple: true, 
                title: "Create Conditional Image") // <--- THIS IS THE NEW TEXT
        }
    }
}

def installed() {
    log.info "Installed Manager App"
}

def updated() {
    log.info "Updated Manager App"
}

def uninstalled() {
    log.info "Uninstalled Manager App"
}
